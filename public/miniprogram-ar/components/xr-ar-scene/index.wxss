/* xr-ar-scene component styles */

/* 开发者工具提示样式 */
.devtools-notice {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  padding: 40rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  text-align: center;
}

.notice-icon {
  font-size: 120rpx;
  margin-bottom: 40rpx;
  animation: bounce 2s infinite;
}

.notice-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.notice-desc {
  font-size: 28rpx;
  opacity: 0.9;
  margin-bottom: 40rpx;
  line-height: 1.6;
}

.notice-tips {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  font-size: 24rpx;
  opacity: 0.8;
}

.notice-tips text {
  text-align: left;
  line-height: 1.5;
}

@keyframes bounce {
  0%,
  100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-20rpx);
  }
}
