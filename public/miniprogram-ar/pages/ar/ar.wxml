<view class="ar-container">
  <xr-ar-scene 
    id="xr-scene"
    width="{{renderWidth}}"
    height="{{renderHeight}}"
    style="width: {{width}}px; height: {{height}}px;"
    bind:sceneReady="handleSceneReady"
    bind:assetsLoaded="handleAssetsLoaded"
    bind:arReady="handleARReady"
  />
</view>

<!-- 状态指示器 -->
<view class="status-indicator" wx:if="{{statusText}}">
  {{statusText}}
</view>

<!-- 控制面板 -->
<view class="control-panel">
  <!-- 模式选择 -->
  <view class="mode-selector">
    <text class="label">获取模式：</text>
    <picker 
      mode="selector" 
      range="{{fetchModes}}" 
      range-key="label"
      value="{{fetchModeIndex}}"
      bindchange="onFetchModeChange"
    >
      <view class="picker">
        {{fetchModes[fetchModeIndex].label}}
      </view>
    </picker>
  </view>

  <!-- Anchor选择（仅在anchor模式下显示） -->
  <view class="anchor-selector" wx:if="{{fetchMode === 'anchor'}}">
    <text class="label">Anchor：</text>
    <picker 
      mode="selector" 
      range="{{anchors}}" 
      range-key="name"
      value="{{anchorIndex}}"
      bindchange="onAnchorChange"
    >
      <view class="picker">
        {{anchors[anchorIndex] ? anchors[anchorIndex].name : '请选择'}}
      </view>
    </picker>
  </view>

  <!-- 重置按钮 -->
  <view class="reset-button" bindtap="handleReset">
    <text>🔄</text>
  </view>
</view>

<!-- 加载中 -->
<view class="loading-overlay" wx:if="{{loading}}">
  <view class="loading-spinner"></view>
  <text class="loading-text">{{loadingText}}</text>
</view>
